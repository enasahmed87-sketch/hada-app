<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="pageTitle">سجلاتي السابقة — هَدَأ</title>
<meta name="theme-color" content="#3D2B3D">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400&family=Tajawal:wght@300;400;500;700&family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#FBF4EE; --plum:#3D2B3D; --rose:#C97B84; --terracotta:#B5573F;
  --sage:#8A9B7E; --line:#E3D4CB; --gold:#C8956D;
}
*{box-sizing:border-box;}
html,body{overflow-x:hidden;}
body{margin:0;background:var(--cream);color:var(--plum);font-family:'Tajawal','Segoe UI',sans-serif;font-weight:300;line-height:1.7;}
body.lang-en{font-family:'Poppins','Segoe UI',sans-serif;}
h1,h2,h3{font-family:'Aref Ruqaa','Tajawal',serif;font-weight:400;margin:0;}
body.lang-en h1,body.lang-en h2,body.lang-en h3{font-family:'Poppins',sans-serif !important;font-weight:600 !important;}
.wrap{max-width:880px;margin:0 auto;padding:28px 20px 80px;}
header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;padding-bottom:18px;border-bottom:2px solid var(--line);margin-bottom:28px;}
header .brand{display:flex;align-items:center;gap:10px;}
header .brand .dot{width:14px;height:14px;border-radius:50%;background:var(--terracotta);}
header h1{font-size:22px;color:var(--plum);}
header .tag{font-size:12px;color:var(--rose);margin-top:2px;}
.header-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.lang-toggle{border:1.5px solid var(--line);background:#fff;border-radius:10px;padding:6px 12px;font-family:inherit;font-size:13px;cursor:pointer;color:var(--plum);}
.lang-toggle:hover{background:var(--cream);}
.backLink{border:1.5px solid var(--line);background:#fff;border-radius:10px;padding:8px 16px;font-family:inherit;font-size:13px;cursor:pointer;color:var(--plum);text-decoration:none;}
.backLink:hover{background:var(--cream);}
.month-group{margin-bottom:26px;}
.month-title{font-size:16px;color:var(--plum);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--line);}
.entry{border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-bottom:10px;background:#fff;}
.entry .top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.entry .date{font-weight:700;font-size:13px;color:var(--terracotta);}
.entry .tags{font-size:12px;color:#6b5a64;}
.entry .note{font-size:13px;color:#4a3c44;margin-top:6px;}
.empty{text-align:center;padding:60px 20px;color:#9b8a92;border:2px dashed var(--line);border-radius:16px;}
.empty a{color:var(--terracotta);font-weight:700;}
.loading{text-align:center;padding:40px 20px;color:#9b8a92;}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="brand">
      <div class="dot"></div>
      <div>
        <h1>هَدَأ</h1>
        <div class="tag" id="pageTag">سجلاتي السابقة</div>
      </div>
    </div>
    <div class="header-actions">
      <button class="lang-toggle" id="langToggle">English</button>
      <a class="backLink" href="/" id="backLink">← الرجوع لليوم</a>
    </div>
  </header>

  <div id="content"><div class="loading" id="loadingText">جاري تحميل السجلات...</div></div>
</div>

<script>
const API_BASE = 'https://hada-api.enasahmed87.workers.dev';
let LANG = localStorage.getItem('hada_lang') || 'ar';

const T = {
  pageTitle: { ar:'سجلاتي السابقة — هَدَأ', en:'My Previous Logs — Hada\u2019' },
  pageTag: { ar:'سجلاتي السابقة', en:'My Previous Logs' },
  backLink: { ar:'← الرجوع لليوم', en:'Back to today →' },
  loadingText: { ar:'جاري تحميل السجلات...', en:'Loading your logs...' },
  needLogin: { ar:'محتاجة تسجّلي دخولك في هَدَأ أول.', en:'You need to log in to Hada\u2019 first.' },
  loginLink: { ar:'الرجوع لتسجيل الدخول →', en:'← Back to login' },
  noOlder: { ar:'ما فيه سجلات سابقة بعد — كل تسجيلاتك لسه ظاهرة بالصفحة الرئيسية 🌿', en:'No previous logs yet — all your entries are still shown on the main page 🌿' },
  loadFail: { ar:'تعذّر تحميل السجلات. حاولي مرة أخرى.', en:'Could not load your logs. Please try again.' },
  improved: { ar:'حسّن نفسيتها:', en:'Improved her mood:' },
  lowered: { ar:'نزّل نفسيتها:', en:'Lowered her mood:' },
};

const MONTH_NAMES = {
  ar: ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'],
  en: ['January','February','March','April','May','June','July','August','September','October','November','December'],
};

const moodEmoji = {1:'😞',2:'😕',3:'😐',4:'🙂',5:'😄'};

function applyStaticLang(){
  document.documentElement.lang = LANG;
  document.documentElement.dir = LANG==='en' ? 'ltr' : 'rtl';
  document.body.classList.toggle('lang-en', LANG==='en');
  document.getElementById('langToggle').textContent = LANG==='en' ? 'العربية' : 'English';
  document.title = T.pageTitle[LANG];
  document.getElementById('pageTag').textContent = T.pageTag[LANG];
  document.getElementById('backLink').textContent = T.backLink[LANG];
  document.getElementById('loadingText').textContent = T.loadingText[LANG];
}

document.getElementById('langToggle').addEventListener('click', ()=>{
  LANG = LANG==='ar' ? 'en' : 'ar';
  localStorage.setItem('hada_lang', LANG);
  applyStaticLang();
  loadEntries();
});

function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

function parseTrigger(raw){
  if(!raw) return { uplift:'', downer:'' };
  try{
    const obj = JSON.parse(raw);
    if(obj && typeof obj === 'object' && ('uplift' in obj || 'downer' in obj)){
      return { uplift: obj.uplift||'', downer: obj.downer||'' };
    }
  }catch(e){}
  return { uplift:'', downer: raw };
}

function monthKey(dateStr){
  const d = new Date(dateStr);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
}
function monthLabel(key){
  const [y,m] = key.split('-');
  return `${MONTH_NAMES[LANG][parseInt(m,10)-1]} ${y}`;
}

async function loadEntries(){
  const token = localStorage.getItem('hada_token');
  const content = document.getElementById('content');
  if(!token){
    content.innerHTML = `<div class="empty">${T.needLogin[LANG]}<br><a href="/">${T.loginLink[LANG]}</a></div>`;
    return;
  }
  content.innerHTML = `<div class="loading">${T.loadingText[LANG]}</div>`;
  try{
    const res = await fetch(`${API_BASE}/api/entries`, { headers:{ 'Authorization':'Bearer '+token } });
    const data = await res.json();
    const entries = (data.entries||[]).sort((a,b)=> new Date(b.date)-new Date(a.date));
    // نستثني أحدث يومين لأنهم ظاهرين أصلاً بالصفحة الرئيسية
    const older = entries.slice(2);
    if(older.length === 0){
      content.innerHTML = `<div class="empty">${T.noOlder[LANG]}</div>`;
      return;
    }
    const groups = {};
    older.forEach(e=>{
      const k = monthKey(e.date);
      if(!groups[k]) groups[k] = [];
      groups[k].push(e);
    });
    const sortedKeys = Object.keys(groups).sort().reverse();
    content.innerHTML = sortedKeys.map(k => `
      <div class="month-group">
        <div class="month-title">${monthLabel(k)}</div>
        ${groups[k].map(e=>{
          const t = parseTrigger(e.trigger);
          return `
          <div class="entry">
            <div class="top">
              <span class="date">${e.date}</span>
              <span class="tags">${e.mood? moodEmoji[e.mood]:''}</span>
            </div>
            <div class="tags">${[...(e.symptoms||[]),...(e.psych||[])].join(' · ')}</div>
            ${e.feeling? `<div class="note">"${escapeHtml(e.feeling)}"</div>`:''}
            ${t.uplift? `<div class="note">${T.improved[LANG]} ${escapeHtml(t.uplift)}</div>`:''}
            ${t.downer? `<div class="note">${T.lowered[LANG]} ${escapeHtml(t.downer)}</div>`:''}
          </div>`;
        }).join('')}
      </div>
    `).join('');
  }catch(e){
    content.innerHTML = `<div class="empty">${T.loadFail[LANG]}</div>`;
  }
}

applyStaticLang();
loadEntries();
</script>
</body>
</html>
