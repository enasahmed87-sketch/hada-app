<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="pageTitle">دردشة — هَدَأ</title>
<meta name="theme-color" content="#3D2B3D">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400&family=Tajawal:wght@300;400;500;700&family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#FBF4EE; --plum:#3D2B3D; --rose:#C97B84; --terracotta:#B5573F;
  --sage:#8A9B7E; --line:#E3D4CB; --gold:#C8956D;
}
*{box-sizing:border-box;}
html,body{overflow-x:hidden;}
body{margin:0;background:var(--cream);color:var(--plum);font-family:'Tajawal','Segoe UI',sans-serif;font-weight:300;line-height:1.7;}
body.lang-en{font-family:'Poppins','Segoe UI',sans-serif;}
h1,h2,h3{font-family:'Aref Ruqaa','Tajawal',serif;font-weight:400;margin:0;}
body.lang-en h1,body.lang-en h2,body.lang-en h3{font-family:'Poppins',sans-serif !important;font-weight:600 !important;}
.wrap{max-width:1180px;margin:0 auto;padding:28px 20px 80px;}
header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;padding-bottom:18px;border-bottom:2px solid var(--line);margin-bottom:28px;position:sticky;top:0;background:var(--cream);z-index:30;padding-top:14px;}
header .brand{display:flex;align-items:center;gap:10px;}
header .brand .dot{width:14px;height:14px;border-radius:50%;background:var(--terracotta);}
header h1{font-size:22px;color:var(--plum);}
header .tag{font-size:12px;color:var(--rose);margin-top:2px;}
.header-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.lang-toggle{border:1.5px solid var(--line);background:#fff;border-radius:10px;padding:6px 12px;font-family:inherit;font-size:13px;cursor:pointer;color:var(--plum);}
.lang-toggle:hover{background:var(--cream);}
nav{display:flex;gap:6px;background:#fff;border:1px solid var(--line);border-radius:14px;padding:4px;flex-wrap:wrap;}
nav a{border:none;background:transparent;padding:8px 14px;border-radius:10px;font-family:inherit;font-size:13px;cursor:pointer;color:var(--plum);transition:.2s;text-decoration:none;display:inline-flex;align-items:center;white-space:nowrap;}
nav a.active{background:var(--plum);color:#fff;}
nav a:hover{background:var(--cream);}
.card{background:#fff;border:1px solid var(--line);border-radius:18px;padding:24px;margin-bottom:20px;}
.intro-banner{background:linear-gradient(135deg,#3D2B3D,#5A3F52);color:#fff;border-radius:20px;padding:22px 26px;margin-bottom:24px;}
.intro-banner h2{font-size:22px;margin-bottom:8px;}
.intro-banner p{font-size:13.5px;opacity:.9;margin:0;max-width:620px;}
.rooms-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;}
.room-card{background:#fff;border:1.5px solid var(--line);border-radius:16px;padding:20px;cursor:pointer;transition:.2s;text-align:center;}
.room-card:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(61,43,61,.12);border-color:var(--rose);}
.room-card .icon{font-size:34px;margin-bottom:10px;}
.room-card h3{font-size:16px;margin-bottom:6px;}
.room-card p{font-size:12.5px;color:#6b5a64;margin:0;}
.room-card.active{border-color:var(--plum);background:var(--cream);}
.chat-shell{display:none;}
.chat-shell.active{display:flex;flex-direction:column;height:560px;}
.chat-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--line);}
.chat-header h3{font-size:17px;}
.backBtn{background:none;border:1.5px solid var(--line);border-radius:10px;padding:6px 14px;font-family:inherit;font-size:13px;cursor:pointer;color:var(--plum);}
.backBtn:hover{background:var(--cream);}
.msgList{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding:6px 2px;}
.msg{max-width:78%;padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.55;background:#F4ECE3;align-self:flex-start;}
.msg.mine{align-self:flex-end;background:var(--plum);color:#fff;}
.msg .who{font-size:11px;font-weight:700;color:var(--terracotta);margin-bottom:3px;}
.msg.mine .who{color:#F3DCD3;}
.msg .when{font-size:10px;opacity:.6;margin-top:4px;}
.empty-state{text-align:center;color:#9b8a92;padding:40px 20px;font-size:13.5px;}
.composer{display:flex;gap:10px;margin-top:14px;}
.composer input{flex:1;border:1.5px solid var(--line);border-radius:10px;padding:10px 14px;font-family:inherit;font-size:14px;background:#FFFDFB;color:var(--plum);}
.composer button{background:var(--plum);color:#fff;border:none;border-radius:10px;padding:0 20px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;}
.composer button:disabled{opacity:.5;cursor:default;}
.guidelines{font-size:11.5px;color:#9b8a92;margin-top:10px;text-align:center;}
.auth-note{text-align:center;padding:60px 20px;color:#6b5a64;}
.auth-note a{color:var(--terracotta);font-weight:700;}
@media(max-width:700px){.chat-shell.active{height:70vh;}}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="brand">
      <div class="dot"></div>
      <div>
        <h1>هَدَأ</h1>
        <div class="tag" id="pageTag">دردشة مجهولة بين العضوات</div>
      </div>
    </div>
    <div class="header-actions">
      <button class="lang-toggle" id="langToggle">English</button>
      <nav>
        <a href="/" id="navHome">اليوم</a>
        <a href="/community.html" class="active" id="navChat">💬 دردشة</a>
        <a href="/archive.html" id="navArchive">📚 الأرشيف</a>
      </nav>
    </div>
  </header>

  <div id="authGate" class="auth-note" style="display:none;">
    <span id="authGateText">محتاجة تسجّلي دخولك في هَدَأ أول عشان تدخلي الدردشة.</span>
    <br><a href="/" id="authGateLink">الرجوع لتسجيل الدخول →</a>
  </div>

  <div id="communityBody" style="display:none;">
    <div class="intro-banner">
      <h2 id="introTitle">مساحة آمنة للكلام</h2>
      <p id="introText">دردشة مجهولة بين عضوات هَدَأ حسب الموضوع. يظهر اسمك الأول فقط، ولا تقدر أي عضوة تعرف بريدك الإلكتروني أبدًا. كوني لطيفة، وتذكّري إنها مساحة دعم لا استشارة طبية أو نفسية متخصصة.</p>
    </div>

    <div id="roomsGrid" class="rooms-grid"></div>

    <div id="chatShell" class="chat-shell card">
      <div class="chat-header">
        <h3 id="roomTitle"></h3>
        <button class="backBtn" id="backToRooms"></button>
      </div>
      <div class="msgList" id="msgList"></div>
      <div class="composer">
        <input type="text" id="msgInput" maxlength="500">
        <button id="sendBtn"></button>
      </div>
      <div class="guidelines" id="guidelinesText"></div>
    </div>
  </div>

</div>

<script>
const API_BASE = 'https://hada-api.enasahmed87.workers.dev';
let LANG = localStorage.getItem('hada_lang') || 'ar';

const T = {
  pageTitleChat: { ar:'دردشة — هَدَأ', en:'Chat — Hada\u2019' },
  pageTag: { ar:'دردشة مجهولة بين العضوات', en:'Anonymous chat between members' },
  navHome: { ar:'اليوم', en:'Today' },
  navChat: { ar:'💬 دردشة', en:'💬 Quick Chat' },
  navArchive: { ar:'📚 الأرشيف', en:'📚 Archive' },
  authGateText: { ar:'محتاجة تسجّلي دخولك في هَدَأ أول عشان تدخلي الدردشة.', en:'You need to log in to Hada\u2019 first to join the chat.' },
  authGateLink: { ar:'الرجوع لتسجيل الدخول →', en:'← Back to login' },
  introTitle: { ar:'مساحة آمنة للكلام', en:'A Safe Space to Talk' },
  introText: { ar:'دردشة مجهولة بين عضوات هَدَأ حسب الموضوع. يظهر اسمك الأول فقط، ولا تقدر أي عضوة تعرف بريدك الإلكتروني أبدًا. كوني لطيفة، وتذكّري إنها مساحة دعم لا استشارة طبية أو نفسية متخصصة.',
                en:'Anonymous, topic-based chat between Hada\u2019 members. Only your first name is shown — no member can ever see your email. Please be kind, and remember this is peer support, not professional medical or psychological advice.' },
  backToRooms: { ar:'→ الغرف', en:'← Rooms' },
  sendBtn: { ar:'إرسال', en:'Send' },
  msgInputPlaceholder: { ar:'اكتبي رسالتك...', en:'Type your message...' },
  guidelinesText: { ar:'هذي مساحة دعم بين عضوات هَدَأ، مو بديل عن استشارة مختصة. في حال أي إساءة أو محتوى مقلق، تواصلي معنا.',
                    en:'This is a peer-support space between Hada\u2019 members, not a substitute for professional care. If you encounter abuse or concerning content, please contact us.' },
  loadingMsgs: { ar:'جاري التحميل...', en:'Loading...' },
  emptyRoom: { ar:'لا توجد رسائل بعد — كوني أول من يبدأ الحديث 🌿', en:'No messages yet — be the first to start the conversation 🌿' },
  sendFail: { ar:'تعذّر إرسال الرسالة', en:'Could not send the message' },
};

const ROOMS = [
  { key:'motherhood', icon:'🤱', title:{ar:'أمومة',en:'Motherhood'}, desc:{ar:'كل شي يخص الأمومة، من الحمل لتربية الأطفال', en:'Everything about motherhood, from pregnancy to raising kids'} },
  { key:'marriage',   icon:'💍', title:{ar:'زواج',en:'Marriage'}, desc:{ar:'العلاقة الزوجية، تحدياتها ولحظاتها', en:'Married life, its challenges and its moments'} },
  { key:'cycle',      icon:'🌙', title:{ar:'الدورة الشهرية',en:'The Cycle'}, desc:{ar:'أعراض، تقلبات، وتجارب مشتركة', en:'Symptoms, mood shifts, and shared experiences'} },
];

function applyLang(){
  document.documentElement.lang = LANG;
  document.documentElement.dir = LANG==='en' ? 'ltr' : 'rtl';
  document.body.classList.toggle('lang-en', LANG==='en');
  document.getElementById('langToggle').textContent = LANG==='en' ? 'العربية' : 'English';
  document.title = T.pageTitleChat[LANG];
  document.getElementById('pageTag').textContent = T.pageTag[LANG];
  document.getElementById('navHome').textContent = T.navHome[LANG];
  document.getElementById('navChat').textContent = T.navChat[LANG];
  document.getElementById('navArchive').textContent = T.navArchive[LANG];
  document.getElementById('authGateText').textContent = T.authGateText[LANG];
  document.getElementById('authGateLink').textContent = T.authGateLink[LANG];
  document.getElementById('introTitle').textContent = T.introTitle[LANG];
  document.getElementById('introText').textContent = T.introText[LANG];
  document.getElementById('backToRooms').textContent = T.backToRooms[LANG];
  document.getElementById('sendBtn').textContent = T.sendBtn[LANG];
  document.getElementById('msgInput').placeholder = T.msgInputPlaceholder[LANG];
  document.getElementById('guidelinesText').textContent = T.guidelinesText[LANG];
  renderRooms();
  if(currentRoom) openRoom(currentRoom, true);
}

document.getElementById('langToggle').addEventListener('click', ()=>{
  LANG = LANG==='ar' ? 'en' : 'ar';
  localStorage.setItem('hada_lang', LANG);
  applyLang();
});

function getToken(){ return localStorage.getItem('hada_token'); }

function renderRooms(){
  const grid = document.getElementById('roomsGrid');
  grid.innerHTML = ROOMS.map(r => `
    <div class="room-card${currentRoom===r.key?' active':''}" data-room="${r.key}">
      <div class="icon">${r.icon}</div>
      <h3>${r.title[LANG]}</h3>
      <p>${r.desc[LANG]}</p>
    </div>
  `).join('');
  grid.querySelectorAll('.room-card').forEach(el=>{
    el.addEventListener('click', ()=> openRoom(el.dataset.room));
  });
}

let currentRoom = null;
let pollTimer = null;
let lastMsgTime = null;

function timeAgo(iso){
  const d = new Date(iso.includes('Z')||iso.includes('+') ? iso : iso+'Z');
  const diffMin = Math.round((Date.now() - d.getTime())/60000);
  if(LANG==='en'){
    if(diffMin < 1) return 'now';
    if(diffMin < 60) return `${diffMin}m ago`;
    const diffH = Math.round(diffMin/60);
    if(diffH < 24) return `${diffH}h ago`;
    return d.toLocaleDateString('en');
  }
  if(diffMin < 1) return 'الآن';
  if(diffMin < 60) return `قبل ${diffMin} د`;
  const diffH = Math.round(diffMin/60);
  if(diffH < 24) return `قبل ${diffH} س`;
  return d.toLocaleDateString('ar');
}

function escapeHtml(s){ return s.replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

async function openRoom(key, silent){
  currentRoom = key;
  const room = ROOMS.find(r=>r.key===key);
  document.getElementById('roomTitle').textContent = `${room.icon} ${room.title[LANG]}`;
  document.querySelectorAll('.room-card').forEach(c=>c.classList.toggle('active', c.dataset.room===key));
  document.getElementById('chatShell').classList.add('active');
  if(!silent){
    document.getElementById('msgList').innerHTML = `<div class="empty-state">${T.loadingMsgs[LANG]}</div>`;
    lastMsgTime = null;
  }
  await loadMessages(true);
  if(pollTimer) clearInterval(pollTimer);
  pollTimer = setInterval(()=>loadMessages(false), 4000);
}

document.getElementById('backToRooms').addEventListener('click', ()=>{
  document.getElementById('chatShell').classList.remove('active');
  document.querySelectorAll('.room-card').forEach(c=>c.classList.remove('active'));
  if(pollTimer) clearInterval(pollTimer);
  currentRoom = null;
});

async function loadMessages(replace){
  if(!currentRoom) return;
  try{
    const qs = (!replace && lastMsgTime) ? `?since=${encodeURIComponent(lastMsgTime)}` : '';
    const res = await fetch(`${API_BASE}/api/rooms/${currentRoom}/messages${qs}`, {
      headers: { 'Authorization': 'Bearer ' + getToken() }
    });
    if(!res.ok) return;
    const data = await res.json();
    const list = document.getElementById('msgList');
    if(replace){
      if(data.messages.length === 0){
        list.innerHTML = `<div class="empty-state">${T.emptyRoom[LANG]}</div>`;
      } else {
        list.innerHTML = data.messages.map(renderMsg).join('');
        list.scrollTop = list.scrollHeight;
      }
    } else if(data.messages.length){
      if(list.querySelector('.empty-state')) list.innerHTML = '';
      list.insertAdjacentHTML('beforeend', data.messages.map(renderMsg).join(''));
      list.scrollTop = list.scrollHeight;
    }
    if(data.messages.length) lastMsgTime = data.messages[data.messages.length-1].created_at;
  }catch(e){ /* silent — polling retries automatically */ }
}

function renderMsg(m){
  return `<div class="msg">
    <div class="who">${escapeHtml(m.display_name)}</div>
    ${escapeHtml(m.content)}
    <div class="when">${timeAgo(m.created_at)}</div>
  </div>`;
}

document.getElementById('sendBtn').addEventListener('click', sendMsg);
document.getElementById('msgInput').addEventListener('keydown', e=>{ if(e.key==='Enter') sendMsg(); });

async function sendMsg(){
  const input = document.getElementById('msgInput');
  const content = input.value.trim();
  if(!content || !currentRoom) return;
  const btn = document.getElementById('sendBtn');
  btn.disabled = true;
  try{
    const res = await fetch(`${API_BASE}/api/rooms/${currentRoom}/messages`, {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer ' + getToken() },
      body: JSON.stringify({ content })
    });
    if(res.ok){
      input.value = '';
      await loadMessages(false);
    } else {
      const data = await res.json().catch(()=>({}));
      alert(data.error || T.sendFail[LANG]);
    }
  }catch(e){ alert(T.sendFail[LANG]); }
  finally{ btn.disabled = false; }
}

(function init(){
  applyLang();
  const token = getToken();
  if(!token){
    document.getElementById('authGate').style.display = 'block';
    return;
  }
  document.getElementById('communityBody').style.display = 'block';
  renderRooms();
})();
</script>
</body>
</html>
